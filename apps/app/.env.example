# Polar.sh — public customer-portal license flow (required for the activation gate)
# Copy to `.env` in this package for local dev (`pnpm dev:tauri`).

# Organization UUID from Polar dashboard
VITE_POLAR_ORG_ID=

# Full checkout link (e.g. buy.polar.sh or polar.sh checkout URL for your product)
VITE_POLAR_CHECKOUT_URL=

# Optional: product UUID (reserved for future checkout builders)
VITE_POLAR_PRODUCT_ID=

# Optional: customer portal URL for “Manage your licenses”
VITE_POLAR_PORTAL_URL=

# Optional: label on the primary button, e.g. "Buy a License — $9"
VITE_POLAR_PRICE_LABEL=

# Optional: use https://sandbox-api.polar.sh when testing against Polar sandbox
# VITE_POLAR_API_BASE=https://sandbox-api.polar.sh
