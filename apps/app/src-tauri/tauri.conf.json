{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autodraw",
  "version": "0.1.0",
  "identifier": "com.cbiering.autodraw",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "license",
        "title": "Activate Autodraw",
        "url": "license.html",
        "width": 520,
        "height": 700,
        "resizable": true,
        "visible": true,
        "center": true,
        "decorations": true
      },
      {
        "label": "main",
        "title": "Untitled Diagram",
        "url": "index.html",
        "width": 1280,
        "height": 820,
        "visible": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["adraw"],
        "name": "Autodraw Diagram",
        "role": "Editor",
        "mimeType": "application/json",
        "description": "Autodraw diagram document"
      }
    ]
  }
}
