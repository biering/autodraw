---
import GithubLink from "@/components/GithubLink.astro";
import { Button, buttonVariants } from "@/components/ui/button";
import { HeroDiagramPreview } from "@/islands/HeroDiagramPreview";
import { HomeSections } from "@/islands/HomeSections";
import { cn } from "@/lib/utils";
import RootLayout from "../layouts/RootLayout.astro";

const title = "Autodraw — Diagram canvas for agents & teams";
const description =
	"Open-source architecture and flow diagrams in the .adraw file format. Free web canvas at autodraw.ink; Mac app for offline files and export (paid, coming soon). CLI and MCP for agents and CI.";
---

<RootLayout {title} {description} ogTitle={title} canonicalPath="/">
	<div class="flex min-h-full flex-col bg-white text-black">
		<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white/90 backdrop-blur-sm">
			<div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
				<a href="/" class="flex items-center gap-2.5 text-lg font-medium tracking-tight">
					<img
						src="/img/logo-1024x.png"
						alt="autodraw logo"
						width="28"
						height="28"
						class="size-8 shrink-0 rounded-lg"
					/>
					<span>Autodraw</span>
				</a>
				<nav class="hidden items-center gap-8 text-base font-normal text-neutral-700 md:flex">
					<a class="hover:text-black" href="#features">Features</a>
					<a class="hover:text-black" href="#workflow">Workflow</a>
					<a class="hover:text-black" href="#pricing">Pricing</a>
					<a class="hover:text-black" href="/spec">Spec</a>
				</nav>
				<div class="flex items-center gap-2 sm:gap-3">
					<GithubLink showLabel />
					<Button disabled size="sm" className="hidden gap-2 sm:inline-flex" title="Coming soon">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="size-5 shrink-0"
							aria-hidden="true"
						>
							<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
							<polyline points="7 10 12 15 17 10" />
							<line x1="12" x2="12" y1="15" y2="3" />
						</svg>
						Download for Mac
					</Button>
					<a href="/app" class={cn(buttonVariants({ variant: "secondary", size: "sm" }))}>Start free in browser</a>
				</div>
			</div>
		</header>

		<main class="flex-1">
			<section class="mx-auto max-w-6xl px-6 pb-24 pt-16 md:pb-28 md:pt-24">
				<div class="mx-auto max-w-2xl text-center">
					<div class="mb-6 flex justify-center md:mb-8" aria-hidden="true">
						<img
							src="/img/logo-1024x.png"
							alt="autodraw logo"
							width="200"
							height="200"
							class="h-20 w-20 object-contain md:h-28 md:w-28 rounded-2xl"
						/>
					</div>
					<h1
						class="text-balance text-5xl font-medium leading-none text-black md:text-7xl"
						style="font-family: ui-rounded, 'SF Pro Rounded', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;"
					>
						Let your agents draw
					</h1>
					<p
						class="mx-auto mt-4 max-w-xl text-balance text-xl font-medium leading-snug text-neutral-800 md:mt-5 md:text-2xl"
						style="font-family: ui-rounded, 'SF Pro Rounded', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;"
					>
						Diagram canvas for agents and teams
					</p>
					<p class="mx-auto mt-6 max-w-xl text-balance text-lg font-normal leading-snug text-neutral-700 md:mt-8 md:text-xl">
						Draw beautiful diagrams, commit it next to
						your code, or send a share link. Teammates open it in the browser. One file, no drift.
					</p>
					<div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
						<Button disabled size="lg" className="gap-2 px-8" title="Coming soon">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="size-5 shrink-0"
								aria-hidden="true"
							>
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
								<polyline points="7 10 12 15 17 10" />
								<line x1="12" x2="12" y1="15" y2="3" />
							</svg>
							Download for Mac
						</Button>
						<a href="/app" class={cn(buttonVariants({ variant: "secondary", size: "lg" }), "px-8")}>Start free in browser</a>
					</div>
					<p class="mt-4 font-mono text-center text-sm text-neutral-500">macOS 14.6+ (Sonoma) · Web canvas is free. No install.</p>
				</div>
			</section>

			<HeroDiagramPreview client:only="react" />

			<HomeSections client:visible />

			<footer class="border-t border-neutral-200 bg-white py-12">
				<div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-8 px-6 md:flex-row md:items-center">
					<div>
						<div class="flex items-center gap-2.5">
							<img
								src="/img/logo-1024x.png"
								alt=""
								width="28"
								height="28"
								class="size-7 shrink-0 rounded-lg"
							/>
							<p class="text-base font-medium text-black">Autodraw</p>
						</div>
						<p class="mt-1 text-sm text-neutral-600">Diagram canvas · autodraw.ink</p>
						<p class="mt-3 flex max-w-md items-center gap-1 text-sm text-neutral-500">
							<span>Made with</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="#f472b6"
								stroke="#ec4899"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="size-4"
								aria-hidden="true"
							>
								<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
							</svg>
							<span>by</span>
							<a
								class="text-black underline underline-offset-4 hover:text-neutral-700"
								href="https://github.com/biering">Christoph Biering</a>
						</p>
					</div>
					<div class="flex flex-col gap-3 text-sm text-neutral-600 md:items-end">
						<a class="hover:text-black" href="/app">Web app</a>
						<a class="hover:text-black" href="/spec">.adraw spec</a>
						<GithubLink showLabel class="w-fit md:ml-auto" />
						<a class="hover:text-black" href="/imprint">Imprint</a>
						<a class="hover:text-black" href="/privacy">Privacy</a>
					</div>
				</div>
			</footer>
		</main>
	</div>
</RootLayout>
