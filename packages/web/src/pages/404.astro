---
import RootLayout from "../layouts/RootLayout.astro";

const title = "Not found · Autodraw";
const description = "This page could not be found.";
---

<RootLayout {title} {description} ogTitle={title} canonicalPath="/404">
	<div class="mx-auto max-w-lg px-6 py-24 text-neutral-800">
		<h1 class="text-2xl font-medium tracking-tight">Page not found</h1>
		<p class="mt-3 text-neutral-600">The URL may be wrong or the page was removed.</p>
		<p class="mt-8">
			<a class="text-black underline underline-offset-4" href="/">← Home</a>
		</p>
	</div>
</RootLayout>
