{
  "name": "@autodraw/cli",
  "version": "0.1.0",
  "description": "Command-line tool for creating, editing, and exporting Autodraw .adraw diagrams",
  "type": "module",
  "bin": {
    "autodraw": "./bin/run.mjs"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json",
    "SKILL.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && oclif manifest",
    "postpack": "oclif manifest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@autodraw/core": "workspace:*",
    "@oclif/core": "^4.2.10",
    "@resvg/resvg-js": "^2.6.2",
    "pdf-lib": "^1.17.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "oclif": "^4.22.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/biering/autodraw.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/biering/autodraw#readme",
  "bugs": {
    "url": "https://github.com/biering/autodraw/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "oclif": {
    "bin": "autodraw",
    "dirname": "autodraw",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "add": {
        "description": "Create nodes or edges"
      },
      "remove": {
        "description": "Delete nodes or edges"
      },
      "move": {
        "description": "Reposition nodes"
      },
      "list": {
        "description": "List diagram elements"
      },
      "patch": {
        "description": "Update nodes or edges in place"
      },
      "show": {
        "description": "Inspect diagram metadata"
      },
      "rename": {
        "description": "Rename diagram"
      },
      "set": {
        "description": "Change diagram settings"
      },
      "copy": {
        "description": "Copy data between diagrams"
      }
    }
  }
}
