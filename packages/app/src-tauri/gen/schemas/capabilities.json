{
  "default": {
    "identifier": "default",
    "description": "Default capability for the main window",
    "remote": {
      "urls": [
        "http://127.0.0.1:1420/*",
        "http://localhost:1420/*",
        "ws://127.0.0.1:1420/*",
        "ws://localhost:1420/*"
      ]
    },
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "core:event:default",
      "dialog:default",
      "fs:default",
      "shell:default"
    ]
  }
}
