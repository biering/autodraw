{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://127.0.0.1:1420/*",
      "http://localhost:1420/*",
      "ws://127.0.0.1:1420/*",
      "ws://localhost:1420/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "fs:default",
    "shell:default"
  ]
}
