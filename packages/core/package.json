{
  "name": "@autodraw/core",
  "version": "0.1.0",
  "description": "Diagram v1 schema, palettes, routing, and SVG rendering for Autodraw",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/biering/autodraw.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/biering/autodraw#readme",
  "bugs": {
    "url": "https://github.com/biering/autodraw/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
